# Database
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=postgres
DB_USER=postgres
DB_PASSWORD=replace_with_db_password

# JWT
SECRET_KEY=replace_with_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
DEBUG=False
BACKEND_PUBLIC_BASE_URL=https://your-backend-domain.onrender.com

# CORS
# Use comma-separated values or JSON array syntax.
BACKEND_CORS_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:5173

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=Pickleball NP SPORTCLUB
SMTP_USE_TLS=True
